<Window x:Class="NeonHiFi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeonHiFi.App"
        xmlns:controls="clr-namespace:NeonHiFi.App.Controls"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeToContent="Height"
        MinWidth="960"
        Background="#FF1A1A1C"
        Title="NeonHiFi" Width="1180">
    <Window.Resources>
        <!-- Fine tiled vertical stripes simulate a brushed-aluminum surface without needing a bitmap asset. -->
        <DrawingBrush x:Key="BrushedMetalBrush" TileMode="Tile" Viewport="0,0,3,10" ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF4E4E54">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,3,10" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF5C5C62">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,1,10" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <LinearGradientBrush x:Key="ChassisSheenBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22FFFFFF" Offset="0" />
            <GradientStop Color="#00000000" Offset="0.4" />
            <GradientStop Color="#22000000" Offset="1" />
        </LinearGradientBrush>

        <!-- Wood grain: a base gradient plus tiled, slightly-wavy darker
             streaks (via a DrawingBrush of thin overlapping ellipses) to
             suggest a real grain pattern instead of a flat gradient. -->
        <LinearGradientBrush x:Key="WoodBaseBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF5A3D28" Offset="0" />
            <GradientStop Color="#FF6E4B31" Offset="0.2" />
            <GradientStop Color="#FF4A311F" Offset="0.45" />
            <GradientStop Color="#FF6B4930" Offset="0.7" />
            <GradientStop Color="#FF3E2A1C" Offset="1" />
        </LinearGradientBrush>

        <DrawingBrush x:Key="WoodGrainOverlayBrush" TileMode="Tile" Viewport="0,0,60,14" ViewportUnits="Absolute" Opacity="0.5">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#2A1A0E00">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="30,2" RadiusX="34" RadiusY="3" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#221A0E00">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="10,8" RadiusX="26" RadiusY="2" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#331A0E00">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="45,11" RadiusX="30" RadiusY="1.6" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <SolidColorBrush x:Key="LcdBackgroundBrush" Color="#FF07110A" />
        <SolidColorBrush x:Key="LcdForegroundBrush" Color="#FF3DFF7A" />

        <RadialGradientBrush x:Key="ScrewBrush" GradientOrigin="0.35,0.3" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
            <GradientStop Color="#FFCFCFCF" Offset="0" />
            <GradientStop Color="#FF7A7A7A" Offset="0.7" />
            <GradientStop Color="#FF3A3A3A" Offset="1" />
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="ButtonMetalBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFD8D8DC" Offset="0" />
            <GradientStop Color="#FFAFAFB4" Offset="0.45" />
            <GradientStop Color="#FF8C8C90" Offset="0.55" />
            <GradientStop Color="#FFB8B8BC" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonLitBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFD98A" Offset="0" />
            <GradientStop Color="#FFE8A93D" Offset="0.5" />
            <GradientStop Color="#FFC9821F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FaderCapBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFECECEC" Offset="0.0" />
            <GradientStop Color="#FFB4B4B8" Offset="0.18" />
            <GradientStop Color="#FFDCDCE0" Offset="0.30" />
            <GradientStop Color="#FF8E8E92" Offset="0.46" />
            <GradientStop Color="#FFC4C4C8" Offset="0.58" />
            <GradientStop Color="#FF7E7E82" Offset="0.74" />
            <GradientStop Color="#FFA8A8AC" Offset="0.86" />
            <GradientStop Color="#FF666666" Offset="1.0" />
        </LinearGradientBrush>

        <DrawingBrush x:Key="FaderTickBrush" TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#FF5A5A5A">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,7,1" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Foreground" Value="#FFE4E4E4" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="#FF3A3A3E" BorderBrush="#FF141416" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF4C4C50" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF262628" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#FF0D0D0E" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="Background" Value="#FF232326" />
        </Style>

        <Style x:Key="PowerButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PowerButtonBorder" Background="#FF3A3A3E" BorderBrush="#FF141416" BorderThickness="1.5" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PowerButtonBorder" Property="BorderBrush" Value="#FF5A5A5A" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PowerButtonBorder" Property="Background" Value="#FF35D453" />
                                <Setter TargetName="PowerButtonBorder" Property="BorderBrush" Value="#FF1F8A34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DspToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FF2A2A2A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg" Background="{StaticResource ButtonMetalBrush}" BorderBrush="#FF0A0A0A" BorderThickness="1.5" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource ButtonLitBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#FF3DFF7A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF141416" />
            <Setter Property="Foreground" Value="#FFE4C88A" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropdownToggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#FF141416" BorderBrush="#FF060607" BorderThickness="1.5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="22" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L5,5 L10,0 Z" Fill="#FFA89060"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#FF1E1E20" BorderBrush="#FF060607" BorderThickness="1.5"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFE4C88A" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBg" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background" Value="#FF3A2E1A" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FaderRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FaderThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Border Background="{StaticResource FaderCapBrush}" BorderBrush="#FF1A1A1A" BorderThickness="1" />
                            <Rectangle Height="2" Fill="#FFF4F4F4" VerticalAlignment="Center" Margin="4,0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mixing-console-style vertical fader: a thin dark groove with tick
             marks flanking it, and a chunky metallic cap - replacing the
             default WPF slider chrome entirely. -->
        <Style x:Key="FaderSliderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="7" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="7" />
                            </Grid.ColumnDefinitions>

                            <Rectangle Grid.Column="0" Width="7" Fill="{StaticResource FaderTickBrush}" Opacity="0.8" />
                            <Rectangle Grid.Column="2" Width="7" Fill="{StaticResource FaderTickBrush}" Opacity="0.8" />

                            <Border Grid.Column="1" Width="4" Background="#FF060606" BorderBrush="#FF000000"
                                    BorderThickness="1" HorizontalAlignment="Center" />

                            <Track x:Name="PART_Track" Grid.Column="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FaderRepeatButtonStyle}" Command="Slider.IncreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FaderRepeatButtonStyle}" Command="Slider.DecreaseLarge" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FaderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Wood-trimmed outer bezel around a brushed-metal chassis - the classic
         70s/80s receiver combination of a wood-cased shell with a metal faceplate. -->
    <Grid Background="{StaticResource WoodBaseBrush}">
        <Grid Background="{StaticResource WoodGrainOverlayBrush}" />
        <Border BorderThickness="34">
            <Grid Background="{StaticResource BrushedMetalBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="5" Background="{StaticResource ChassisSheenBrush}" IsHitTestVisible="False" />

                <!-- Custom title bar, replacing the default window chrome entirely. -->
                <Border Grid.Row="0" Background="#FF141416" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="PowerButton" Style="{StaticResource PowerButtonStyle}" Click="PowerButton_Click">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF141416" />
                            </ToggleButton>
                            <Ellipse x:Name="PowerLed" Width="8" Height="8" Margin="10,0,12,0" Fill="#FF3A1010" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="N E O N H I F I" Foreground="#FFEDEDED" FontFamily="Consolas" FontWeight="Bold" FontSize="20" />
                                <TextBlock Text="80s SOUND SYSTEM" Foreground="#FF8A8A8A" FontFamily="Consolas" FontSize="10" Margin="1,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Content="&#x2212;" Style="{StaticResource ChromeButtonStyle}" Click="Minimize_Click" />
                            <Button Content="&#x2715;" Style="{StaticResource ChromeButtonStyle}" Click="Close_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Screen row: spectrum "CRT" display (with a dB scale) + now-playing LCD panel. -->
                <Border Grid.Row="1" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,4,8,20" VerticalAlignment="Stretch">
                            <TextBlock Text="dB" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="11" Margin="0,0,0,6" />
                            <TextBlock Text="+6" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" />
                            <TextBlock Text="0" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" Margin="0,14,0,0" />
                            <TextBlock Text="-6" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" Margin="0,14,0,0" />
                            <TextBlock Text="-12" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" Margin="0,14,0,0" />
                            <TextBlock Text="-18" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" Margin="0,14,0,0" />
                            <TextBlock Text="-24" Foreground="#FF3DFF7A" FontFamily="Consolas" FontSize="10" Margin="0,14,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                            <controls:SpectrumDisplay x:Name="SpectrumDisplayControl" Height="220" Magnitudes="{Binding Magnitudes}" />
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource PanelBorderStyle}" Background="{StaticResource LcdBackgroundBrush}">
                            <TextBlock x:Name="NowPlayingText" Text="-- STANDBY --" Foreground="{StaticResource LcdForegroundBrush}"
                                       FontFamily="Consolas" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="8" />
                        </Border>
                    </Grid>
                </Border>

                <!-- VU meters row. -->
                <Border Grid.Row="2" Padding="16,0,16,14">
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="18">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Margin="10,0">
                                <controls:VuMeterDisplay Width="360" Height="230" Level="{Binding LeftLevel}" PeakLevel="{Binding LeftPeak}" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ScrewBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ScrewBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" />
                            </Grid>
                            <Grid Margin="10,0">
                                <controls:VuMeterDisplay Width="360" Height="230" Level="{Binding RightLevel}" PeakLevel="{Binding RightPeak}" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ScrewBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ScrewBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Graphic EQ row: preset + DSP toggles, then the fader bank. -->
                <Border Grid.Row="3" Padding="16,0,16,16">
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="20,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                                <TextBlock Text="PRESET" Foreground="Gainsboro" FontFamily="Consolas" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="PresetSelector" Width="150" Style="{StaticResource PresetComboBoxStyle}"
                                          SelectionChanged="PresetSelector_SelectionChanged" />
                                <ToggleButton x:Name="BassBoostToggle" Content="BASS" Style="{StaticResource DspToggleStyle}"
                                              Margin="20,0,0,0" Click="DspEffectToggle_Click" />
                                <ToggleButton x:Name="StereoWidthToggle" Content="WIDE" Style="{StaticResource DspToggleStyle}"
                                              Margin="8,0,0,0" Click="DspEffectToggle_Click" />
                                <ToggleButton x:Name="WarmthToggle" Content="WARM" Style="{StaticResource DspToggleStyle}"
                                              Margin="8,0,0,0" Click="DspEffectToggle_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Width="26" Margin="0,0,4,0">
                                    <TextBlock Text="+12" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Right" />
                                    <TextBlock Text="0" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Right" Margin="0,120,0,0" />
                                    <TextBlock Text="-12" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Right" Margin="0,118,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="EqBandsPanel" Orientation="Horizontal" />
                                <StackPanel Width="26" Margin="4,0,0,0">
                                    <TextBlock Text="+12" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Left" />
                                    <TextBlock Text="0" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Left" Margin="0,120,0,0" />
                                    <TextBlock Text="-12" Foreground="Gainsboro" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Left" Margin="0,118,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Bottom branding bar. -->
                <Border Grid.Row="4" Background="#FF141416" Padding="16,8">
                    <Grid>
                        <TextBlock Text="N E O N H I F I" Foreground="#FF8A8A8A" FontFamily="Consolas" FontSize="11"
                                   HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="STEREO GRAPHIC EQUALIZER" Foreground="#FF8A8A8A" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Ellipse Width="7" Height="7" Fill="#FF3DFF7A" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
